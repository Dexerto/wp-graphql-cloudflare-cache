#!/bin/sh

# Validate conventional commit message format
# https://www.conventionalcommits.org

MSG=$(head -1 "$1")

# Allow release commits from the bot
if echo "$MSG" | grep -qE "^Release [0-9]+\.[0-9]+\.[0-9]+$"; then
  exit 0
fi

PATTERN="^(feat|fix|docs|style|refactor|test|chore|ci|perf|build|revert)(\(.+\))?: .+"

if ! echo "$MSG" | grep -qE "$PATTERN"; then
  echo ""
  echo "ERROR: Commit message does not follow Conventional Commits format."
  echo ""
  echo "  Got:      $MSG"
  echo "  Expected: <type>: <description>"
  echo ""
  echo "  Valid types: feat, fix, docs, style, refactor, test, chore, ci, perf, build, revert"
  echo ""
  echo "  Examples:"
  echo "    feat: add purge-all button"
  echo "    fix(purge): handle empty cache tags"
  echo "    chore: update dependencies"
  echo ""
  exit 1
fi
