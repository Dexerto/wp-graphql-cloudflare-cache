{
	"core": "WordPress/WordPress#6.7",
	"phpVersion": "8.2",
	"plugins": [
		".",
		"https://downloads.wordpress.org/plugin/wp-graphql.2.11.1.zip",
		"https://github.com/wp-graphql/wp-graphql-smart-cache/releases/download/v2.0.1/wpgraphql-smart-cache.zip"
	],
	"config": {
		"WP_DEBUG": true,
		"WP_DEBUG_LOG": true,
		"GRAPHQL_DEBUG": true
	},
	"lifecycleScripts": {
		"afterStart": "composer install --working-dir=/var/www/html/wp-content/plugins/wp-graphql-cloudflare-cache --no-interaction 2>/dev/null || true"
	}
}
